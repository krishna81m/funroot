    {
      "id": "q1-terrified-friend",
      "orderIndex": 1,
      "type": "quiz",
      "text": "Your friend suddenly looks terrified, stressed, and is sweating. What happened?\n\nHost reveal: Something happened to my friend just now... what can it be? He is getting married!",
      "options": [
        "He checked his bank balance",
        "He lost his passport",
        "He forgot his phone password",
        "He is getting married"
      ],
      "correctIndices": [
        3
      ],
      "timeLimit": 60,
      "pointsMultiplier": 1,
      "mediaUrl": null,
      "background": "/backgrounds/marriage-survival-guide-birthday/q1-terrified-friend.webp"
    },
